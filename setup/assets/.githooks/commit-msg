#!/bin/bash

# Get the commit message from the temporary file provided by Git
commit_msg=$(cat "$1")

# 1. Define the pattern for allowed prefixes
# note, docs, fix, refactor, asset, chore
prefix_pattern="^(note|docs|fix|refactor|asset|chore): .+"

# Check prefix and general format
if [[ ! $commit_msg =~ $prefix_pattern ]]; then
  echo "❌ ERROR: Illegal commit message format."
  echo "Your message must start with: note:, docs:, fix:, refactor:, asset:, or chore:"
  exit 1
fi

# 2. Enforce strictly lowercase (No uppercase allowed)
# This checks if the message contains any uppercase characters
if [[ "$commit_msg" =~ [[:upper:]] ]]; then
  echo "❌ ERROR: Uppercase letters are not allowed."
  echo "Please rewrite your commit message using only lowercase letters."
  exit 1
fi

exit 0